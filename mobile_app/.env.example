## Flutter client configuration (development)
#
# Реальный Flutter-проект находится в `mobile_app/nutri_ai_app/`.
# Этот файл оставлен для справки, используйте `.env.example` в папке `nutri_ai_app`.

API_BASE_URL=http://localhost:8080

# OAuth Client ID (обычно выглядит как: xxxx.apps.googleusercontent.com)
# Должен совпадать с "Web application" OAuth client в Google Cloud Console.
GOOGLE_CLIENT_ID=
