    {
      "name": "Auth - Verify / Login / Login With Code",
      "item": [
        {
          "name": "TC-AUTH-VER-001 Verify email with correct code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{register_email}}\",\n  \"code\": \"{{verify_code}}\"\n}"
            },
            "description": "Paste the real email verification code into {{verify_code}}."
          }
        },
        {
          "name": "TC-AUTH-VER-002 Verify email with wrong code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{register_email}}\",\n  \"code\": \"{{wrong_code}}\"\n}"
            }
          }
        },
        {
          "name": "TC-AUTH-VER-003 Verify email with expired code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{register_email}}\",\n  \"code\": \"{{expired_code}}\"\n}"
            },
            "description": "Manual setup: use a genuinely expired code if available."
          }
        },
        {
          "name": "TC-AUTH-VER-004 Verify unregistered email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{unknown_email}}\",\n  \"code\": \"{{verify_code}}\"\n}"
            }
          }
        },
        {
          "name": "TC-AUTH-VER-005 Re-verify already verified email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{verified_email}}\",\n  \"code\": \"{{verify_code}}\"\n}"
            },
            "description": "Precondition: verified_email is already verified. Current backend behavior is idempotent."
          }
        },
        {
          "name": "TC-AUTH-LOGIN-001 Login with valid email/password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('access_token', json.access_token || '');",
                  "pm.environment.set('refresh_token', json.refresh_token || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
